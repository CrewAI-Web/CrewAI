# ============================================================================
#  crewai_claude_v1 — environment template
#  Copy this file to ".env" and fill in the keys you need.
#  You only need keys for the providers your agents actually use.
#  (.env is gitignored — never commit real secrets.)
# ============================================================================

# ---- LLM PROVIDERS --------------------------------------------------------

# Google Gemini  (already in use by the original agents — keep it)
#   Get a free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# DeepSeek  (you already have this; powers Backend Engineer)
#   Get a key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Anthropic Claude  (Frontend / Mobile / DevOps / GitHub agents)
#   Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI  (UI/UX Designer + LinkedIn Content Creator)
#   Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ---- AUTOMATION TOOLS -----------------------------------------------------

# GitHub  (GitHub Automation & Release Specialist) — FREE, official API
#   Create a fine-grained token: https://github.com/settings/tokens?type=beta
#   Grant: "Contents: Read & write" + "Pull requests: Read & write" on the target repo.
GITHUB_TOKEN=

# LinkedIn  (LinkedIn Content Creator) — FREE "Share on LinkedIn" product
#   1. Create an app:        https://www.linkedin.com/developers/apps
#   2. Add products:         "Share on LinkedIn" + "Sign In with LinkedIn (OIDC)"
#   3. OAuth scopes:         w_member_social, openid, profile
#   4. Run 3-legged OAuth -> paste the member access token below
#   5. Author URN from /v2/userinfo, format: urn:li:person:XXXXXXXX
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# ---- OPTIONAL: web search for the Research agent --------------------------
# Serper (Google Search API) free tier: https://serper.dev
SERPER_API_KEY=
